{
  "name": "@suffolk/speckle",
  "version": "0.1.0",
  "description": "TypeScript client for the Speckle GraphQL API.",
  "license": "MIT",
  "author": "david-morgan-suffolk <dmorgan@suffolk.com>",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "speckle",
    "graphql",
    "aec",
    "bim",
    "client",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/david-morgan-suffolk/speckle-ts.git"
  },
  "bugs": {
    "url": "https://github.com/david-morgan-suffolk/speckle-ts/issues"
  },
  "homepage": "https://github.com/david-morgan-suffolk/speckle-ts#readme",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run clean && npm run build"
  },
  "dependencies": {
    "graphql-request": "^7.1.2",
    "subscriptions-transport-ws": "^0.11.0"
  },
  "peerDependencies": {
    "graphql": "^16.9.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/introspection": "^4.0.3",
    "@graphql-codegen/schema-ast": "^4.1.0",
    "@graphql-codegen/typescript": "^4.1.1",
    "@graphql-codegen/typescript-graphql-request": "^6.2.0",
    "@graphql-codegen/typescript-operations": "^4.3.1",
    "@types/bun": "latest",
    "graphql": "^16.9.0",
    "typescript": "^5.6.3"
  }
}
