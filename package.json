{
  "name": "@suffolk/speckle",
  "version": "0.2.1",
  "private": true,
  "description": "TypeScript client for the Speckle GraphQL API.",
  "license": "MIT",
  "author": "david-morgan-suffolk <dmorgan@suffolk.com>",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js",
      "default": "./dist/cli/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "speckle": "./dist/cli/index.js"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "patches",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "speckle",
    "graphql",
    "aec",
    "bim",
    "client",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/david-morgan-suffolk/speckle-ts.git"
  },
  "bugs": {
    "url": "https://github.com/david-morgan-suffolk/speckle-ts/issues"
  },
  "homepage": "https://github.com/david-morgan-suffolk/speckle-ts#readme",
  "engines": {
    "node": ">=18"
  },
  "patchedDependencies": {
    "@speckle/objectloader2@2.28.0": "patches/@speckle%2Fobjectloader2@2.28.0.patch"
  },
  "scripts": {
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "test": "bun test",
    "snapshot:insights": "bun test test/insights.live.test.ts",
    "account:info": "bun run scripts/account-info.ts",
    "template:new": "bun run scripts/template-new.ts",
    "cli": "bun run src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src test scripts codegen.ts",
    "lint:fix": "biome lint --write src test scripts codegen.ts",
    "format": "biome format --write src test scripts codegen.ts",
    "prepare": "bun run clean && bun run build"
  },
  "dependencies": {
    "@speckle/objectloader2": "2.28.0",
    "@speckle/objectsender": "2.28.0",
    "graphql-request": "^7.1.2",
    "subscriptions-transport-ws": "^0.11.0",
    "zod": "^4"
  },
  "peerDependencies": {
    "@opentui/core": "^0.2.0",
    "@opentui/react": "^0.2.0",
    "citty": "^0.1.6",
    "fuse.js": "^7.0.0",
    "graphql": "^16.9.0",
    "picocolors": "^1.1.0",
    "react": "^19.2.0",
    "yaml": "^2.6.0"
  },
  "peerDependenciesMeta": {
    "@opentui/core": {
      "optional": true
    },
    "@opentui/react": {
      "optional": true
    },
    "citty": {
      "optional": true
    },
    "fuse.js": {
      "optional": true
    },
    "picocolors": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "yaml": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/introspection": "^4.0.3",
    "@graphql-codegen/schema-ast": "^4.1.0",
    "@graphql-codegen/typescript": "^4.1.1",
    "@graphql-codegen/typescript-graphql-request": "^6.2.0",
    "@graphql-codegen/typescript-operations": "^4.3.1",
    "@opentui/core": "^0.2.0",
    "@opentui/react": "^0.2.0",
    "@types/bun": "latest",
    "@types/react": "^19.2.0",
    "citty": "^0.1.6",
    "fuse.js": "^7.3.0",
    "graphql": "^16.9.0",
    "picocolors": "^1.1.0",
    "react": "^19.2.0",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.6.3",
    "yaml": "^2.6.0"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
